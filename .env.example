# GateFlow Environment Configuration

# FastAPI Port (default: 8000)
PORT=8000

# Rate Limiting (optional: Redis URL, e.g., redis://localhost:6379/0)
# If left blank, in-memory rate limiting will be used.
REDIS_URL=

# Google Gemini API key (optional: required for LLM-based phrasing layer)
# If left blank, offline template-based phrasing is used.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
